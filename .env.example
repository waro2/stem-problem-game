# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT  —  copy to .env, docker-compose loads it automatically
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL container credentials (docker-compose only)
POSTGRES_USER=stem_game
POSTGRES_PASSWORD=stem_game
POSTGRES_DB=stem_game

# Prisma / Express — connection to the local postgres container
DATABASE_URL=postgresql://stem_game:stem_game@localhost:5432/stem_game

# Express API URL as seen by the browser (Vite injects this at build time)
VITE_API_URL=http://localhost:3001

# Origins allowed to make state-changing (non-GET) requests (CSRF protection)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase project JWT secret — Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# Supabase project URL — used to fetch the JWKS for JWT verification (jose)
# Settings → API → Project URL
SUPABASE_URL=


# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION  —  set these in the Railway and Vercel dashboards (never commit)
# ─────────────────────────────────────────────────────────────────────────────

# ── Railway (backend) ─────────────────────────────────────────────────────────

# Railway PostgreSQL plugin injects DATABASE_URL automatically.
# No action needed — Railway sets ${{Postgres.DATABASE_URL}} for the service.
# DATABASE_URL=<injected by Railway>

# Public URL of your Vercel frontend (used for CSRF origin check)
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Supabase JWT secret (same value as local, from Supabase dashboard)
# SUPABASE_JWT_SECRET=<from Supabase → Settings → API>

# Supabase project URL (same value as local) — set this wherever the Express
# server actually runs (e.g. Render dashboard → Environment)
# SUPABASE_URL=<from Supabase → Settings → API → Project URL>

# PORT is set automatically by Railway; no need to configure it.

# ── Vercel (frontend) ─────────────────────────────────────────────────────────

# Public URL of your Railway backend service
# Set this in Vercel: Project → Settings → Environment Variables
# VITE_API_URL=https://your-app.up.railway.app

# ── GitHub Actions secrets (Settings → Secrets → Actions) ────────────────────

# Railway deployment
# RAILWAY_TOKEN=<Railway dashboard → Settings → Tokens → New token>
# RAILWAY_SERVICE_ID=<Railway service UUID from the service URL>

# Vercel deployment
# VERCEL_TOKEN=<Vercel → Settings → Tokens → Create>
# VERCEL_ORG_ID=<Vercel → Settings → General → Your ID>
# VERCEL_PROJECT_ID=<Vercel project → Settings → General → Project ID>

# Production database (Railway PostgreSQL public URL, for CI migrations)
# DATABASE_URL=<Railway → PostgreSQL plugin → Connect → Public URL>
