{
  "name": "stem-problem-game",
  "version": "0.1.0",
  "description": "Educational STEM puzzle game — variable identification & formula activation",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "start": "npx prisma migrate deploy && npx tsx src/server/index.ts",
    "server": "tsx src/server/index.ts",
    "server:dev": "tsx watch src/server/index.ts",
    "jobs:aggregate": "tsx src/server/jobs/runNightlyAggregation.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:load": "vitest run --config vitest.load.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src --ext .ts,.tsx",
    "cap:gen-assets": "tsx scripts/gen-assets.ts",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:run:ios": "npm run cap:sync && npx cap run ios",
    "cap:run:android": "npm run cap:sync && npx cap run android",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@prisma/client": "^5.0.0",
    "@supabase/supabase-js": "^2.108.1",
    "express": "^4.22.2",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^7.18.0",
    "zod": "^4.4.3",
    "zustand": "^4.5.0"
  },
  "prisma": {
    "schema": "src/db/schema.prisma"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@playwright/test": "^1.61.0",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/ui": "^1.6.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prisma": "^5.0.0",
    "sharp": "^0.35.1",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.0"
  }
}
